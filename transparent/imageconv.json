      "barWidth": 62,
      "data": [0, 0, 0, 0],
      "label": {
        "show": true,
        "position": "top",
        "formatter": "{c}%"
      }
    },
    {
      "name": "GPT-5.2 Pro",
      "type": "bar",
      "barWidth": 62,
      "data": [100, 50, 100, 90],
      "label": {
        "show": true,
        "position": "top",
        "formatter": "{c}%"
      }
    }
