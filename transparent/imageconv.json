    "name": "Appropriate Uncertainty Expression Rate",
    "nameLocation": "middle",
    "nameGap": 70,
    "nameTextStyle": {
      "fontSize": 18
    },
    "splitLine": {
      "lineStyle": {
        "type": "dashed",
        "opacity": 0.5
      }
